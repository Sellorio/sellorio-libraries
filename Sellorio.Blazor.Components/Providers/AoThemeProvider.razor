<MudThemeProvider Theme="_theme" />

@code {
	private MudTheme? _theme;

	[Parameter]
	public string LightPrimary { get; set; } = "#224678";

	[Parameter]
	public string LightSecondary { get; set; } = "#a174db";

	[Parameter]
	public string DarkPrimary { get; set; } = "#3976cc";

	[Parameter]
	public string DarkSecondary { get; set; } = "#412f59";

	protected override void OnInitialized()
	{
		_theme = new()
		{
			PaletteLight = new PaletteLight
			{
				Primary = LightPrimary,
				Secondary = LightSecondary
			},
			PaletteDark = new PaletteDark
			{
				Primary = DarkPrimary,
				Secondary = DarkSecondary
			},
			Typography = new()
			{
				H1 = new H1Typography
				{
					FontSize = "2.5rem"
				},
				H2 = new H2Typography
				{
					FontSize = "2.0rem"
				},
				H3 = new H3Typography
				{
					FontSize = "1.7rem"
				},
				H4 = new H4Typography
				{
					FontSize = "1.3rem",
					FontWeight = "bold"
				}
			}
		};
	}
}
